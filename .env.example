# Copy to .env and fill in as needed. All optional for Day 1 (retrieval runs
# fully offline with the HashingEmbedder).

# Demo business name (shown in /health and used in prompts later).
BUSINESS_NAME=Nimbus

# Embedder backend: auto | fastembed | openai | hashing
#   auto  -> fastembed if installed, else openai if key present, else hashing
EMBEDDER=auto

# Only needed if EMBEDDER=openai (or auto falls through to it).
# OPENAI_API_KEY=sk-...

# Generation provider (used from Day 2 onward, not Day 1).
# ANTHROPIC_API_KEY=sk-ant-...
